# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=lead_generator
POSTGRES_USER=lead_user
POSTGRES_PASSWORD=lead_secret
DATABASE_URL=postgresql+asyncpg://lead_user:lead_secret@postgres:5432/lead_generator

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=-1001234567890

# ── Scraper ───────────────────────────────────────────────────────────────────
SCRAPER_TARGET_URLS=https://example.com/leads,https://example2.com/contacts
SCRAPER_INTERVAL_SECONDS=300
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; LeadBot/1.0)

# ── Scoring Weights ───────────────────────────────────────────────────────────
SCORE_WEIGHT_DATA_COMPLETENESS=40
SCORE_WEIGHT_SOURCE=25
SCORE_WEIGHT_PHONE_PRESENT=20
SCORE_WEIGHT_EMAIL_DOMAIN=15

# ── Distributor ───────────────────────────────────────────────────────────────
HOT_SCORE_THRESHOLD=70
WARM_SCORE_THRESHOLD=40

# ── General ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
